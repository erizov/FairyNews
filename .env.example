# Скопируйте в `.env` и заполните. Файл `.env` не коммитьте.

# OpenAI или прокси (AITunnel / OpenRouter): см. app/llm_connect_try.py
OPENAI_API_KEY=
# AITunnel: https://api.aitunnel.ru/v1
# Предпочтительно для совместимых прокси; иначе см. OPENAI_BASE_URL
OPENAI_API_BASE=
OPENAI_BASE_URL=
OPENAI_MODEL=
# Приоритет smoke-test: LLM_CONNECT_TRY_MODEL, иначе OPENAI_MODEL, иначе
# openai/gpt-5. Не оставляйте LLM_CONNECT_TRY_MODEL= пустым (будет ошибка).
# У AITunnel без слэша в id подставится префикс openai/ (прокси = OpenRouter).
LLM_CONNECT_TRY_MODEL=openai/gpt-5

# Лимит размера JSON-отчёта в БД (байт UTF-8). 0 = без лимита.
FAIRYNEWS_REPORT_MAX_BYTES=200000
# Отчёты: SQLite до 100 записей (по умолчанию data/reports/runs.db)
# FAIRYNEWS_REPORTS_DB_PATH=
# Сохранять прогоны при stub LLM (для pytest/отладки)
# FAIRYNEWS_PERSIST_STUB_REPORTS=1
# RSS недоступен: показать 6 нейтральных карточек вместо пустого списка
# FAIRYNEWS_NEWS_OFFLINE=1

# RAG: гибрид (dense+BM25, RRF), итерация, сжатие чанков (см. rag/rag_enhanced)
# FAIRYNEWS_RAG_LEGACY=1
# FAIRYNEWS_RAG_ITERATIVE=0
# FAIRYNEWS_RAG_RRF_K=60
# FAIRYNEWS_RAG_CHUNK_MAX_CHARS=900
# FAIRYNEWS_RAG_CHROMA_POOL=120

DEEPSEEK_API_KEY=

GROQ_KEY=
GROQ_API_KEY=

GIGACHAT_API_KEY=
# Если заданы и OpenAI, и GigaChat: по умолчанию берётся OpenAI (меньше сюрпризов
# при устаревшем ключе Сбера). Вернуть приоритет GigaChat:
# FAIRYNEWS_PREFER_GIGACHAT=1
# Всегда игнорировать GIGACHAT_API_KEY (например для локальной отладки OpenAI):
# FAIRYNEWS_SKIP_GIGACHAT=1

# --- TEST 1: разные модели по этапам (news → story → audit → qa) ---
# FAIRYNEWS_LLM_PER_STAGE=1
# Этапы: FAIRYNEWS_STAGE_<NEWS|STORY|AUDIT|QA>_BACKEND и _MODEL
# backend: openai | groq | deepseek | gigachat | gemini
# Пример (подставьте реальные id из кабинетов провайдеров):
# FAIRYNEWS_STAGE_NEWS_BACKEND=openai
# FAIRYNEWS_STAGE_NEWS_MODEL=gpt-5.4-nano
# FAIRYNEWS_STAGE_STORY_BACKEND=groq
# FAIRYNEWS_STAGE_STORY_MODEL=llama-4-maverick
# FAIRYNEWS_STAGE_AUDIT_BACKEND=openai
# FAIRYNEWS_STAGE_AUDIT_MODEL=gpt-5.4-mini
# FAIRYNEWS_STAGE_QA_BACKEND=gemini
# FAIRYNEWS_STAGE_QA_MODEL=gemini-2.5-flash
# GEMINI_API_KEY=
# GEMINI_OPENAI_BASE=https://generativelanguage.googleapis.com/v1beta/openai
# Не смешивайте FAIRYNEWS_LLM_MODE=stub с отдельными real-backend этапами.

# --- TEST 2: одна модель на все этапы (сходные/идентичные настройки) ---
# FAIRYNEWS_LLM_UNIFORM_STAGES=1
# FAIRYNEWS_UNIFORM_BACKEND=openai
# FAIRYNEWS_UNIFORM_MODEL=gpt-4o-mini
# Сравнение TEST1 vs TEST2: см. scripts/run_test1_test2_comparison.py

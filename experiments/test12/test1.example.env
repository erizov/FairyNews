# TEST 1 — разные модели на этапах (скопируйте в test1.env и подставьте ключи).
FAIRYNEWS_LLM_PER_STAGE=1
FAIRYNEWS_RAG_BACKEND=snapshot
FAIRYNEWS_TEST_PROFILE=test1

# Пример: один провайдер, разные имена моделей (или разные backend’ы).
FAIRYNEWS_STAGE_NEWS_BACKEND=openai
FAIRYNEWS_STAGE_NEWS_MODEL=gpt-4o-mini
FAIRYNEWS_STAGE_STORY_BACKEND=openai
FAIRYNEWS_STAGE_STORY_MODEL=gpt-4o
FAIRYNEWS_STAGE_AUDIT_BACKEND=openai
FAIRYNEWS_STAGE_AUDIT_MODEL=gpt-4o-mini
FAIRYNEWS_STAGE_QA_BACKEND=openai
FAIRYNEWS_STAGE_QA_MODEL=gpt-4o-mini
